@model IEnumerable<InventoryTestMvc.Data.Dto.StockReportDto>

@{
    ViewData["Title"] = "รายงานการนำเข้า-ส่งออกสินค้า";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2>📋 รายงานการเคลื่อนไหวคลังสินค้า (Stock Movement Report)</h2>
            <p class="text-muted mb-0">ประวัติการนำเข้าสินค้า (PO) และการส่งออกสินค้า (Delivery) ทั้งหมดในระบบ</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">🔙 กลับหน้าคลังสินค้าคงเหลือ</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">วันที่-เวลา</th>
                            <th>ประเภทรายการ</th>
                            <th>เลขที่เอกสาร</th>
                            <th>ข้อมูลสินค้า</th>
                            <th class="text-end pe-3">จำนวน</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">ยังไม่มีประวัติการนำเข้าหรือส่งออกในระบบ</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 text-muted small">@item.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (item.RefType == "IN")
                                        {
                                            <span class="badge bg-success px-3 py-2">📥 นำเข้า (PO)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2">📤 ส่งออก (Delivery)</span>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark">@item.DocumentNumber</td>
                                    <td>
                                        <div class="fw-bold text-secondary">@item.ProductName</div>
                                        <small class="text-muted">ID: @item.ProductId | SKU: @item.SKU</small>
                                    </td>
                                    <td class="text-end pe-3 fw-bold @(item.RefType == "IN" ? "text-success" : "text-danger")">
                                        @(item.RefType == "IN" ? "+" : "-")@item.Qty.ToString("N0") ชิ้น
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>