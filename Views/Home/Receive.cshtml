@model InventoryTestMvc.Data.Dto.ReceiveProductDto

@{
    ViewData["Title"] = "รับสินค้าเข้าคลัง";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">📥 ฟอร์มรับสินค้าเข้าคลัง (PO)</h4>
        </div>
        <div class="card-body">
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-action="Receive" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="PONumber" class="form-label">เลขที่ใบสั่งซื้อ (PO Number)</label>
                    <input asp-for="PONumber" class="form-bar form-control" placeholder="เช่น PO-202605-001" required />
                    <span asp-validation-for="PONumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SupplierName" class="form-label">ชื่อผู้จำหน่าย (Supplier)</label>
                    <input asp-for="SupplierName" class="form-control" placeholder="เช่น บริษัท ซัพพลาย จำกัด" required />
                    <span asp-validation-for="SupplierName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductId" class="form-label">รหัสสินค้า (Product ID)</label>
                    <input asp-for="ProductId" class="form-control" type="number" min="1" placeholder="ระบุตัวเลข ID สินค้า" required />
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Quantity" class="form-label">จำนวน (Quantity)</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" placeholder="0" required />
                        <span asp-validation-for="Quantity" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="UnitPrice" class="form-label">ราคาต่อหน่วย (Unit Price)</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" required />
                        <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">🔙 ย้อนกลับ</a>
                    <button type="submit" class="btn btn-success">💾 บันทึกรับเข้าคลัง</button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}